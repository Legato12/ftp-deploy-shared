# ftp-deploy-shared — configuration template.
#
# Copy this file to `.env` (in the same folder as deploy.py), fill in your
# values, and run `python deploy.py <version>`. The `.env` file is read on
# every run; never commit your real `.env` to git.

# ─── FTP credentials (required) ──────────────────────────────────────────────
FTP_HOST=ftp.yourhost.example          # the FTP server hostname or IP
FTP_USER=yourftpuser
FTP_PASS=yourftppassword
FTP_PORT=21                            # default 21 for plain, 21 for FTPS-explicit, 990 FTPS-implicit
FTP_TLS=0                              # 1 to use FTPS (encrypted FTP)

# ─── Public site URL (required if SQL migration is enabled) ──────────────────
# The deploy script triggers the SQL helper via HTTPS GET on this URL.
SITE_URL=https://yourdomain.example
INSECURE_TLS=0                         # 1 if your origin has a self-signed cert (rare)
# Optional: if your site is behind HTTP Basic Auth (e.g. a temp staging space),
# the deploy script will send this as `Authorization: Basic <base64>`.
# SITE_BASIC_AUTH=siteadmin:110

# ─── MySQL/MariaDB (used by the server-side SQL helper) ──────────────────────
# IMPORTANT: DB_HOST is what the SERVER uses, not your machine. On shared
# hosting this is almost always `localhost` — the PHP helper runs on the
# server and connects via the loopback. Do NOT put the public DB IP here.
DB_HOST=localhost
DB_NAME=yourdbname
DB_USER=yourdbuser
DB_PASS=yourdbpassword

# ─── Local source paths ──────────────────────────────────────────────────────
# Your built web bundle (a .zip of the site root contents).
ZIP_PATH=./web-update.zip

# Optional: a single migration .sql with CREATE/ALTER + INSERTs. Leave blank
# to skip the SQL migration step entirely.
# Format expectations: standard SQL, multi-row INSERTs allowed, apostrophes
# escaped as `''`. See docs/HOW-IT-WORKS.md for the parsing rules.
SQL_PATH=./db-deploy.sql

# ─── Optional: versioned binary asset (game map, installer, etc.) ────────────
# The deploy script can also push a single binary by version-matching a
# pattern under ASSET_DIR. Leave ASSET_DIR blank to skip.
ASSET_DIR=                             # e.g. C:\Users\me\Downloads\builds
ASSET_PATTERN=*{version}*              # `{version}` is replaced with deploy arg
ASSET_REMOTE_DIR=/wwwroot/downloads    # where on the server to put it

# ─── Optional: paths to delete on the server (files removed from project) ────
# Comma-separated, relative to WEB_ROOT. The deploy script DELE's them after
# uploading the new tree.
EXTRA_DELETE=                          # e.g. old-page.php,deprecated/old.html

# ─── Server layout ───────────────────────────────────────────────────────────
WEB_ROOT=/wwwroot                      # web root on the FTP server. Common values:
                                       #   /wwwroot   — 西部数码, many CN hosts
                                       #   /htdocs    — most pure-ftpd defaults
                                       #   /public_html — cPanel
                                       #   /www       — some custom setups
DEPLOY_DIR=_deploy                     # temp folder under WEB_ROOT for the SQL helper

# ─── File permissions (applied via SITE CHMOD after each upload) ─────────────
# Required when Apache runs as a different user from your FTP user. Leave a
# value blank to skip chmod for that kind. 644 for files / 755 for dirs is
# the universal "owner can write, others can read" setup that Apache needs.
FILE_CHMOD=644
DIR_CHMOD=755

# ─── HTTP client (the SQL migration trigger) ─────────────────────────────────
# Cloudflare's default-bot rules block the stock Python User-Agent with
# `1010 The owner of this website has banned your access based on your
# browser's signature`. We send a real browser UA to dodge it.
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/130.0.0.0 Safari/537.36
